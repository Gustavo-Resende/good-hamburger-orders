@namespace GoodHamburger.Blazor.Shared

@if (Visible)
{
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;
                background:rgba(0,0,0,0.5);z-index:1000;
                display:flex;align-items:center;justify-content:center;">
        <div class="card" style="width:400px;">
            <div class="card-body">
                <h5 class="card-title">@Title</h5>
                <p>@Message</p>
                <div class="d-flex justify-content-end gap-2">
                    <button class="btn btn-secondary" @onclick="OnCancel">Cancelar</button>
                    <button class="btn btn-danger" @onclick="OnConfirm">@ConfirmLabel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Confirmar";
    [Parameter] public string Message { get; set; } = "Tem certeza?";
    [Parameter] public string ConfirmLabel { get; set; } = "Confirmar";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
